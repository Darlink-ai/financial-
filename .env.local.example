# ---- Connexion à Postgres ----
# Locale (via Supabase CLI : sortie de `supabase start`) :
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres

# Production (Supabase Cloud → Project Settings → Database → Connection string [URI]) :
# Utilise la chaîne POOLER (port 6543) pour Vercel/serverless.
# DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ---- Supabase JS client (utilisé plus tard pour Auth / Storage) ----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<copie depuis `supabase start` ou Project Settings → API>

# Server-side key (jamais exposée au client)
SUPABASE_SERVICE_ROLE_KEY=<copie depuis Project Settings → API>
